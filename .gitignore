## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
Omni.API/**/*.rsuser
Omni.API/**/*.suo
Omni.API/**/*.user
Omni.API/**/*.userosscache
Omni.API/**/*.sln.docstates

# Build results
Omni.API/[Bb]in/
Omni.API/[Oo]bj/
Omni.API/[Ee]xt/
Omni.API/[Ll]og/
Omni.API/[Ll]ogs/

# MSBuild Binary and Structured Log
Omni.API/**/*.binlog

# MSBuild response files
!Omni.API/**/MSBuild.rsp
!Omni.API/**/Directory.Build.rsp

# Visual Studio 14+ cache/options directory
Omni.API/.vs/
Omni.API/.vs/**

# Visual Studio 15+ auto generated files
Omni.API/Generated\ Files/

# Local History for Visual Studio
Omni.API/.localhistory/

# Visual Studio History (VSHistory) files
Omni.API/.vshistory/

# Backup folder for Package Reference Convert tool in Visual Studio 2017
Omni.API/MigrationBackup/

# VS Code files for those working on multiple tools
Omni.API/.vscode/*
!Omni.API/.vscode/settings.json
!Omni.API/.vscode/tasks.json
!Omni.API/.vscode/launch.json
!Omni.API/.vscode/extensions.json
Omni.API/**/*.code-workspace

# Local History for Visual Studio Code
Omni.API/.history/

# MSTest test Results
Omni.API/[Tt]est[Rr]esult*/
Omni.API/**/[Bb]uild[Ll]og.*

# NUnit
Omni.API/**/*.VisualState.xml
Omni.API/**/TestResult.xml
Omni.API/**/nunit-*.xml

# Benchmark Results
Omni.API/BenchmarkDotNet.Artifacts/

# .NET Core
Omni.API/**/project.lock.json
Omni.API/**/project.fragment.lock.json
Omni.API/artifacts/

# ASP.NET Scaffolding
Omni.API/**/ScaffoldingReadMe.txt

# StyleCop
Omni.API/**/StyleCopReport.xml

# Files built by Visual Studio
Omni.API/**/*_i.c
Omni.API/**/*_p.c
Omni.API/**/*_h.h
Omni.API/**/*.ilk
Omni.API/**/*.meta
Omni.API/**/*.obj
Omni.API/**/*.iobj
Omni.API/**/*.pch
Omni.API/**/*.pdb
Omni.API/**/*.ipdb
Omni.API/**/*.pgc
Omni.API/**/*.pgd
Omni.API/**/*.sbr
Omni.API/**/*.tlb
Omni.API/**/*.tli
Omni.API/**/*.tlh
Omni.API/**/*.tmp
Omni.API/**/*.tmp_proj
Omni.API/**/*_wpftmp.csproj
Omni.API/**/*.log
Omni.API/**/*.tlog
Omni.API/**/*.vspscc
Omni.API/**/*.vssscc
Omni.API/**/.builds
Omni.API/**/*.pidb
Omni.API/**/*.svclog
Omni.API/**/*.scc

# Visual Studio profiler
Omni.API/**/*.psess
Omni.API/**/*.vsp
Omni.API/**/*.vspx
Omni.API/**/*.sap

# Visual Studio Trace Files
Omni.API/**/*.e2e

# ReSharper is a .NET coding add-in
Omni.API/_ReSharper*/
Omni.API/**/*.[Rr]e[Ss]harper
Omni.API/**/*.DotSettings.user

# TeamCity is a build add-in
Omni.API/**/_TeamCity*

# DotCover is a Code Coverage Tool
Omni.API/**/*.dotCover

# AxoCover is a Code Coverage Tool
Omni.API/.axoCover/*
!Omni.API/.axoCover/settings.json

# Coverlet is a free, cross platform Code Coverage Tool
Omni.API/**/coverage*.json
Omni.API/**/coverage*.xml
Omni.API/**/coverage*.info

# Visual Studio code coverage results
Omni.API/**/*.coverage
Omni.API/**/*.coveragexml

# Publish Web Output
Omni.API/**/*.[Pp]ublish.xml
Omni.API/**/*.azurePubxml
# Note: Comment the next line if you want to checkin your web deploy settings,
# but database connection strings (with potential passwords) will be unencrypted
Omni.API/**/*.pubxml
Omni.API/**/*.publishproj

# Microsoft Azure Web App publish settings. Comment the next line if you want to
# checkin your Azure Web App publish settings, but sensitive information contained
# in these scripts will be unencrypted
Omni.API/PublishScripts/

# NuGet Packages
Omni.API/**/*.nupkg
# NuGet Symbol Packages
Omni.API/**/*.snupkg
# The packages folder can be ignored because of Package Restore
Omni.API/**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!Omni.API/**/[Pp]ackages/build/
# Uncomment if necessary however generally it will be regenerated when needed
#!**/[Pp]ackages/repositories.config
# NuGet v3's project.json files produces more ignorable files
Omni.API/**/*.nuget.props
Omni.API/**/*.nuget.targets

# Windows Store app package directories and files
Omni.API/AppPackages/
Omni.API/BundleArtifacts/
Omni.API/**/Package.StoreAssociation.xml
Omni.API/**/_pkginfo.txt
Omni.API/**/*.appx
Omni.API/**/*.appxbundle
Omni.API/**/*.appxupload

# Visual Studio cache files
# files ending in .cache can be ignored
Omni.API/**/*.[Cc]ache
# but keep track of directories ending in .cache
!Omni.API/?*.[Cc]ache/

# Others
Omni.API/ClientBin/
Omni.API/**/~$*
Omni.API/**/*~
Omni.API/**/*~.*
Omni.API/**/*.dbmdl
Omni.API/**/*.dbproj.schemaview
Omni.API/**/*.jfm
Omni.API/**/*.pfx
Omni.API/**/*.publishsettings
Omni.API/**/orleans.codegen.cs

# RIA/Silverlight projects
Omni.API/Generated_Code/

# Backup & report files from converting an old project file
# to a newer Visual Studio version. Backup files are not needed,
# because we have git ;-)
Omni.API/_UpgradeReport_Files/
Omni.API/Backup*/
Omni.API/**/UpgradeLog*.XML
Omni.API/**/UpgradeLog*.htm
Omni.API/ServiceFabricBackup/
Omni.API/**/*.rptproj.bak

# Microsoft Fakes
Omni.API/FakesAssemblies/

# CodeRush personal settings
Omni.API/.cr/personal

# JetBrains Rider
Omni.API/**/*.sln.iml
